FROM python:3.12-slim

WORKDIR /app

# Set environment variables to prevent Python from writing .pyc files and to ensure that output is not buffered
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app:/app/scripts

# Optional seeding parameters, can be provided via build args or runtime env vars.
# These env vars are translated into CLI flags by the CMD shell expansion below;
# the Python application reads them only as argparse parameters, never via os.getenv.
ARG DATA_START_DATE
ARG DATA_END_DATE
ARG DOWNLOAD_JC
ARG PARALLEL_MONTHS
ARG DB_LOADER_WORKERS
ENV DATA_START_DATE=${DATA_START_DATE} \
    DATA_END_DATE=${DATA_END_DATE} \
    DOWNLOAD_JC=${DOWNLOAD_JC} \
    PARALLEL_MONTHS=${PARALLEL_MONTHS} \
    DB_LOADER_WORKERS=${DB_LOADER_WORKERS}

# Copy the requirements and excluded packages list to the container
COPY requirements.txt /app/requirements.txt
COPY dockers/excluded-packages.txt /tmp/excluded-packages.txt

# Use awk to filter out excluded packages from the requirements and install the remaining packages
RUN awk -F'==' 'NR==FNR { excluded[$1]=1; next } !($1 in excluded)' \
    /tmp/excluded-packages.txt /app/requirements.txt > /tmp/requirements.docker.txt \
    && pip install --no-cache-dir -r /tmp/requirements.docker.txt \
    && rm /tmp/requirements.docker.txt /tmp/excluded-packages.txt

# Copy the application code and scripts to the container
COPY scripts/ /app/scripts/
COPY src/backend /app/src/backend
COPY postgres/ /app/postgres/

# Command to run the data download script
CMD ["sh", "-c", "python /app/scripts/download_data.py ${DATA_START_DATE:+--start-date $DATA_START_DATE} ${DATA_END_DATE:+--end-date $DATA_END_DATE} ${DOWNLOAD_JC:+--download-jc} ${PARALLEL_MONTHS:+--parallel-months $PARALLEL_MONTHS} ${DB_LOADER_WORKERS:+--db-loader-workers $DB_LOADER_WORKERS}"]
